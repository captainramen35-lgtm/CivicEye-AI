rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Issues: anyone authenticated can read; only authenticated users can create
    // Only the reporter or authority role can update
    match /issues/{issueId} {
      allow read: if true; // public read for map visibility
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Verifications: authenticated users can create and read
    match /verifications/{verifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Badges: public read, only backend (admin SDK) writes
    match /badges/{badgeId} {
      allow read: if true;
      allow write: if false; // admin SDK only
    }
  }
}
